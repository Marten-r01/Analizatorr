import java.io.File
import java.math.BigDecimal
import java.math.RoundingMode
import kotlin.system.exitProcess

object AnalizatorConsoleApp {
    private val allowedSymbols = setOf('A', 'T', 'G', 'C')

    @JvmStatic
    fun main(args: Array<String>) {
        runCatching {
            require(args.size == 1) { "Укажи путь к FASTA-файлу: AnalizatorConsoleApp <path>" }
            val file = File(args[0])
            require(file.exists()) { "Файл не найден: ${file.path}" }
            require(file.isFile) { "Указанный путь не является файлом: ${file.path}" }

            val parsed = parseSingleFasta(file.readLines())
            val stats = calculateStats(parsed.sequence)

            buildString {
                appendLine("Header: ${parsed.header}")
                appendLine("Length: ${stats.length}")
                appendLine("A: ${stats.aCount}")
                appendLine("T: ${stats.tCount}")
                appendLine("G: ${stats.gCount}")
                appendLine("C: ${stats.cCount}")
                appendLine("GC-content: ${stats.gcPercent}%")
            }.trimEnd()
        }.onSuccess {
            println(it)
        }.onFailure {
            System.err.println("Ошибка: ${it.message}")
            exitProcess(1)
        }
    }

    private fun parseSingleFasta(lines: List<String>): ParsedFasta {
        val meaningfulLines = lines.map { it.trim() }.filter { it.isNotEmpty() }
        require(meaningfulLines.isNotEmpty()) { "Файл пустой" }

        val firstLine = meaningfulLines.first()
        require(firstLine.startsWith(">")) { "FASTA-заголовок должен начинаться с символа '>'" }

        val headersCount = meaningfulLines.count { it.startsWith(">") }
        require(headersCount == 1) { "Консольный прототип поддерживает только одну FASTA-запись" }

        val header = firstLine.removePrefix(">").trim()
        require(header.isNotEmpty()) { "Заголовок FASTA пустой" }

        val sequence = meaningfulLines
            .drop(1)
            .joinToString(separator = "")
            .uppercase()

        require(sequence.isNotEmpty()) { "После заголовка отсутствует последовательность" }

        val invalidIndex = sequence.indexOfFirst { it !in allowedSymbols }
        require(invalidIndex == -1) {
            "Обнаружен недопустимый символ '${sequence[invalidIndex]}' в позиции ${invalidIndex + 1}"
        }

        return ParsedFasta(header, sequence)
    }

    private fun calculateStats(sequence: String): SequenceStats {
        val length = sequence.length
        require(length > 0) { "Последовательность пустая" }

        val aCount = sequence.count { it == 'A' }
        val tCount = sequence.count { it == 'T' }
        val gCount = sequence.count { it == 'G' }
        val cCount = sequence.count { it == 'C' }
        val gcRaw = (gCount + cCount).toDouble() * 100.0 / length.toDouble()
        val gcPercent = BigDecimal(gcRaw).setScale(2, RoundingMode.HALF_UP).toPlainString()

        return SequenceStats(
            length = length,
            aCount = aCount,
            tCount = tCount,
            gCount = gCount,
            cCount = cCount,
            gcPercent = gcPercent
        )
    }

    private data class ParsedFasta(
        val header: String,
        val sequence: String
    )

    private data class SequenceStats(
        val length: Int,
        val aCount: Int,
        val tCount: Int,
        val gCount: Int,
        val cCount: Int,
        val gcPercent: String
    )
}
